@page
@model Pethub.Pages.AccountManagement.DetailsModel

@{
    ViewData["Title"] = "Account Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Account Details</h1>
    <a asp-page="./Index" class="btn btn-secondary">← Back to List</a>
</div>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white fw-semibold">
                @Model.Account.Username
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Username</dt>
                    <dd class="col-sm-8">@Model.Account.Username</dd>

                    <dt class="col-sm-4 text-muted">Email</dt>
                    <dd class="col-sm-8">@Model.Account.Email</dd>

                    <dt class="col-sm-4 text-muted">Gender</dt>
                    <dd class="col-sm-8">@Model.Account.Gender</dd>

                    <dt class="col-sm-4 text-muted">Address</dt>
                    <dd class="col-sm-8">@Model.Account.Address</dd>

                    <dt class="col-sm-4 text-muted">Contact</dt>
                    <dd class="col-sm-8">@Model.Account.Contact</dd>

                    <dt class="col-sm-4 text-muted">Birthday</dt>
                    <dd class="col-sm-8">@Model.Account.Birthday.ToString("MMMM dd, yyyy")</dd>

                    <dt class="col-sm-4 text-muted">Age</dt>
                    <dd class="col-sm-8">@Model.Account.Age</dd>
                </dl>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-page="./Edit" asp-route-id="@Model.Account.Id" class="btn btn-primary btn-sm">Edit</a>
                <a asp-page="./Delete" asp-route-id="@Model.Account.Id" class="btn btn-danger btn-sm">Delete</a>
            </div>
        </div>
    </div>
</div>
