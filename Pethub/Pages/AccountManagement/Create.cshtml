@page
@model Pethub.Pages.AccountManagement.CreateModel
@{
    ViewData["Title"] = "Create Account";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account — PetHub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Admin.css" />
</head>
<body>

    <div class="admin-wrapper">

        <aside class="admin-sidebar">
            <div class="admin-sidebar-inner">
                <div class="admin-logo">
                    <img src="~/images/paws1.png" alt="paw" />
                    <span>PETHUB</span>
                </div>
                <div class="admin-role-badge">Admin</div>
                <nav class="admin-nav">
                    <a href="/Admin/Dashboard" class="admin-nav-item">Dashboard</a>
                    <a href="/AccountManagement/Index" class="admin-nav-item active">Account Management</a>
                </nav>
                <div class="admin-sidebar-footer">
                    <a href="/Logout" class="admin-logout-btn">Logout</a>
                </div>
            </div>
        </aside>

        <main class="admin-main">

            <div class="admin-topbar">
                <h4 class="admin-topbar-title">Create Account</h4>
                <a href="/AccountManagement/Index" class="action-btn action-view" style="padding:8px 16px;font-size:13px;">Back to List</a>
            </div>

            <div class="admin-table-container">
                <div class="dash-card" style="max-width:600px;">

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                        <div class="mb-3">
                            <label asp-for="Account.Username" class="form-label fw-semibold"></label>
                            <span class="text-danger">*</span>
                            <input asp-for="Account.Username" class="form-control" />
                            <span asp-validation-for="Account.Username" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Account.Password" class="form-label fw-semibold"></label>
                            <span class="text-danger">*</span>
                            <div class="input-group">
                                <input id="createPwd" asp-for="Account.Password" type="password" class="form-control" />
                                <button type="button" class="btn btn-outline-secondary"
                                        onclick="togglePassword('createPwd','createPwdBtn')"
                                        id="createPwdBtn" tabindex="-1">
                                    Show
                                </button>
                            </div>
                            <span asp-validation-for="Account.Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Account.Email" class="form-label fw-semibold"></label>
                            <span class="text-danger">*</span>
                            <input asp-for="Account.Email" class="form-control" />
                            <span asp-validation-for="Account.Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Account.Gender" class="form-label fw-semibold"></label>
                            <span class="text-danger">*</span>
                            <select asp-for="Account.Gender" class="form-select">
                                <option value="">— Select Gender —</option>
                                <option>Male</option>
                                <option>Female</option>
                            </select>
                            <span asp-validation-for="Account.Gender" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Account.Address" class="form-label fw-semibold"></label>
                            <span class="text-danger">*</span>
                            <input asp-for="Account.Address" class="form-control" />
                            <span asp-validation-for="Account.Address" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Account.Contact" class="form-label fw-semibold"></label>
                            <span class="text-danger">*</span>
                            <input asp-for="Account.Contact" class="form-control" placeholder="09XXXXXXXXX" />
                            <span asp-validation-for="Account.Contact" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Account.Birthday" class="form-label fw-semibold"></label>
                            <span class="text-danger">*</span>
                            <input asp-for="Account.Birthday" type="date" class="form-control" />
                            <span asp-validation-for="Account.Birthday" class="text-danger small"></span>
                            <div class="text-muted small mt-1">Age is calculated automatically from the birthday.</div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="action-btn action-approve" style="padding:10px 24px;font-size:14px;">Create</button>
                            <a href="/AccountManagement/Index" class="action-btn action-view" style="padding:10px 24px;font-size:14px;">Cancel</a>
                        </div>
                    </form>

                </div>
            </div>

        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
</body>
</html>
