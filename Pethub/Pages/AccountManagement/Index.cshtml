@page
@model Pethub.Pages.AccountManagement.IndexModel
@{
    ViewData["Title"] = "Account Management";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Account Management — PetHub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Admin.css" />
</head>
<body>

    <div class="admin-wrapper">

        <aside class="admin-sidebar">
            <div class="admin-sidebar-inner">
                <div class="admin-logo">
                    <img src="~/images/paws1.png" alt="paw" />
                    <span>PETHUB</span>
                </div>
                <div class="admin-role-badge">Admin</div>
                <nav class="admin-nav">
                    <a href="/Admin/Dashboard" class="admin-nav-item">Dashboard</a>
                    <a href="/AccountManagement/Index" class="admin-nav-item active">Account Management</a>
                </nav>
                <div class="admin-sidebar-footer">
                    <a href="/Logout" class="admin-logout-btn">Logout</a>
                </div>
            </div>
        </aside>

        <main class="admin-main">

            <div class="admin-topbar">
                <h4 class="admin-topbar-title">Account Management</h4>
                <a asp-page="Create" class="action-btn action-approve" style="padding:8px 16px;font-size:13px;">+ Create New</a>
            </div>

            <div class="admin-table-container">
                @if (!Model.Account.Any())
                {
                    <div class="admin-empty">No accounts found.</div>
                }
                else
                {
                    <table class="table admin-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>USERNAME</th>
                                <th>EMAIL</th>
                                <th>GENDER</th>
                                <th>CONTACT</th>
                                <th>AGE</th>
                                <th class="text-center">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Account)
                            {
                                <tr>
                                    <td class="text-muted">@item.Id</td>
                                    <td class="fw-semibold">@item.Username</td>
                                    <td class="text-muted">@item.Email</td>
                                    <td>
                                        @if (item.Gender == "Male")
                                        {
                                            <span class="status-badge" style="background:#e3f2fd;color:#1565c0;">Male</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge" style="background:#fce4ec;color:#880e4f;">Female</span>
                                        }
                                    </td>
                                    <td>@item.Contact</td>
                                    <td>@item.Age yrs</td>
                                    <td class="text-center">
                                        <a asp-page="./Details" asp-route-id="@item.Id" class="action-btn action-view">Details</a>
                                        <a asp-page="./Edit" asp-route-id="@item.Id" class="action-btn action-approve">Edit</a>
                                        <a asp-page="./Delete" asp-route-id="@item.Id" class="action-btn action-reject">Delete</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
