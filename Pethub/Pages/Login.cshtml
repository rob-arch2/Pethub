@* Login page for users to sign in. Layout is disabled for a focused form view. *@
@page
@model Pethub.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<link rel="stylesheet" href="~/css/site.css">

<nav class="navbar">
    <div class="logo">
        <img src="~/images/paws1.png" alt="paw">
        <span>PETHUB</span>
    </div>
    <div class="menu">
        <a href="/">Home</a>
        <a href="/About">About</a>
        <a href="/Services">Services</a>
        <a href="/Contact">Contact</a>
    </div>
    <div class="nav-buttons">
        <a asp-page="/Login" class="login-btn">Login</a>
        <a asp-page="/Register" class="register-btn">Register</a>
    </div>
</nav>

<div class="login-container">
    <div class="dog">
        <img src="~/images/dog.png" alt="Dog">
    </div>

    <div class="login-box">
        <h2>LOGIN</h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div style="color:red; margin-bottom:12px;">@Model.ErrorMessage</div>
        }

        <form method="post">
            <div class="input-box">
                <input asp-for="Email" type="email" placeholder="Email address" required />
            </div>

            <div class="input-box">
                <input id="loginPassword" asp-for="Password" type="password" placeholder="Password" required />
                <button type="button"
                        class="toggle-password"
                        id="loginPasswordToggle"
                        onclick="togglePassword('loginPassword', 'loginPasswordToggle')"
                        tabindex="-1"
                        aria-label="Show password">
                    Show
                </button>
            </div>

            <div class="remember">
                <input asp-for="RememberMe" type="checkbox" />
                <label>Remember me?</label>
            </div>

            <button type="submit" class="login-button">Login</button>
        </form>

        <p class="forgot">Forgot your password?</p>
        <p class="register">
            Don't have an account?
            <a href="/Register">Register</a>
        </p>
    </div>
</div>
<script src="~/js/site.js"></script>