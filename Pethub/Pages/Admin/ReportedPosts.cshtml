@page
@model Pethub.Pages.Admin.ReportedPostsModel
@{
    ViewData["Title"] = "Reported Posts";
    Layout = "_Layout";
    var successMsg = TempData["Success"] as string;
}

<div class="admin-topbar">
    <h4 class="admin-topbar-title">Report Management</h4>
</div>

<div class="admin-table-container">

    @if (!string.IsNullOrEmpty(successMsg))
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" style="background-color: #e6f4ea; color: #2e7d32;">
            <i class="bi bi-check-circle-fill me-2"></i> @successMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="dash-card d-flex align-items-center p-4 h-100 border-start border-4" style="border-left-color: #f57f17 !important;">
                <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; font-size: 20px;">
                    <i class="bi bi-flag-fill"></i>
                </div>
                <div>
                    <div class="text-muted small fw-bold text-uppercase">Active Reports</div>
                    <div class="fs-4 fw-bold" style="color: #2c3e50;">@Model.TotalActiveReports</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="dash-card d-flex align-items-center p-4 h-100 border-start border-4" style="border-left-color: #3949ab !important;">
                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; font-size: 20px;">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div>
                    <div class="text-muted small fw-bold text-uppercase">Unique Users Reported</div>
                    <div class="fs-4 fw-bold" style="color: #2c3e50;">@Model.UniqueUsersReported</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="dash-card d-flex align-items-center p-4 h-100 border-start border-4" style="border-left-color: #c62828 !important;">
                <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; font-size: 20px;">
                    <i class="bi bi-person-x-fill"></i>
                </div>
                <div>
                    <div class="text-muted small fw-bold text-uppercase">Total Banned Users</div>
                    <div class="fs-4 fw-bold" style="color: #2c3e50;">@Model.TotalBannedUsers</div>
                </div>
            </div>
        </div>
    </div>

    <div class="dash-card">
        <div class="dash-card-title border-bottom pb-3 mb-0">Actionable Reports</div>

        <div class="table-responsive">
            <table class="table align-middle admin-table mb-0">
                <thead style="background: #f8f9fa;">
                    <tr>
                        <th class="text-muted fw-bold text-uppercase small py-3 px-4">Date</th>
                        <th class="text-muted fw-bold text-uppercase small py-3 px-4">Reported Post Title</th>
                        <th class="text-muted fw-bold text-uppercase small py-3 px-4">Reported By</th>
                        <th class="text-muted fw-bold text-uppercase small py-3 px-4">Reason</th>
                        <th class="text-muted fw-bold text-uppercase small py-3 px-4 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Reports)
                    {
                        <tr style="border-bottom: 1px solid #f0f2f5;">
                            <td class="text-muted px-4">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="fw-semibold px-4" style="color: #2c3e50;">@item.Post.Title</td>
                            <td class="px-4">
                                <span class="badge bg-light text-dark border">@@@item.Reporter.Username</span>
                            </td>
                            <td class="px-4">
                                <span class="status-badge status-rejected">@item.ReasonCategory</span>
                            </td>
                            <td class="px-4 text-end">
                                <form method="post" class="d-inline-flex gap-2">
                                    <button type="submit" asp-page-handler="Dismiss" asp-route-reportId="@item.Id" class="action-btn action-view">Dismiss</button>
                                    <button type="submit" asp-page-handler="DeletePost" asp-route-postId="@item.PostId" class="action-btn action-reject" onclick="return confirm('Delete this post permanently?');">Delete Post</button>
                                    <button type="submit" asp-page-handler="BanUser" asp-route-accountId="@item.Post.AccountId" class="action-btn text-white" style="background: #1e2125;" onclick="return confirm('Ban the author of this post?');">Ban Author</button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Reports.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="text-muted fs-1 mb-2"><i class="bi bi-shield-check"></i></div>
                                <div class="text-muted fw-semibold">All clear! No reported posts at this time.</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>