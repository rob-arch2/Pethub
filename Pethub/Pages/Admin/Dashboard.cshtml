@* Admin dashboard: shows summary stats and recent account activity for admins. *@
@page
@model Pethub.Pages.Admin.DashboardModel
@{
}

<div class="admin-wrapper">

    <!-- SIDEBAR -->
    <aside class="admin-sidebar">
        <div class="admin-sidebar-inner">
            <div class="admin-logo">
                <img src="~/images/paws1.png" alt="paw" />
                <span>PETHUB</span>
            </div>
            <div class="admin-role-badge">Admin</div>
            <nav class="admin-nav">
                <a href="/Admin/Dashboard" class="admin-nav-item active">
                    Dashboard
                </a>
                <a href="/AccountManagement/Index" class="admin-nav-item">
                    Account Management
                </a>
            </nav>
            <div class="admin-sidebar-footer">
                <a href="/Login" class="admin-logout-btn">Logout</a>
            </div>
        </div>
    </aside>

    <!-- MAIN -->
    <main class="admin-main">

        <div class="admin-topbar">
            <h4 class="admin-topbar-title">Dashboard</h4>
            <span class="admin-post-count">Overview of registered accounts</span>
        </div>

        <div class="dash-content">

            <!-- ── ROW 1: Summary stat cards ── -->
            <div class="dash-stat-row">

                <div class="dash-stat-card dash-stat-total">
                    <div class="dash-stat-icon"></div>
                    <div class="dash-stat-value">@Model.TotalAccounts</div>
                    <div class="dash-stat-label">Total Accounts</div>
                </div>

                <div class="dash-stat-card dash-stat-male">
                    <div class="dash-stat-icon"></div>
                    <div class="dash-stat-value">@Model.MaleCount</div>
                    <div class="dash-stat-label">Male</div>
                    <div class="dash-stat-pct">@Model.MalePercent%</div>
                </div>

                <div class="dash-stat-card dash-stat-female">
                    <div class="dash-stat-icon"></div>
                    <div class="dash-stat-value">@Model.FemaleCount</div>
                    <div class="dash-stat-label">Female</div>
                    <div class="dash-stat-pct">@Model.FemalePercent%</div>
                </div>

                <div class="dash-stat-card dash-stat-young">
                    <div class="dash-stat-icon"></div>
                    <div class="dash-stat-value">@Model.AgeGroup1</div>
                    <div class="dash-stat-label">Ages 18–25</div>
                    <div class="dash-stat-pct">@Model.Ag1p%</div>
                </div>

            </div>

            <!-- ── ROW 2: Gender bar + Age breakdown ── -->
            <div class="dash-row-2">

                <!-- Gender distribution -->
                <div class="dash-card">
                    <div class="dash-card-title">Gender Distribution</div>

                    @if (Model.TotalAccounts == 0)
                    {
                        <p class="text-muted small">No accounts yet.</p>
                    }
                    else
                    {
                        <div class="dash-gender-bar-wrap">
                            <div class="dash-gender-bar">
                                <div class="dash-bar-male" style="width:@Model.MalePercent%">
                                    @if (Model.MalePercent > 8)
                                    {
                                        <span>@Model.MalePercent%</span>
                                    }
                                </div>
                                <div class="dash-bar-female" style="width:@Model.FemalePercent%">
                                    @if (Model.FemalePercent > 8)
                                    {
                                        <span>@Model.FemalePercent%</span>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="dash-gender-legend">
                            <span class="dash-legend-dot dash-dot-male"></span> Male (@Model.MaleCount)
                            &nbsp;&nbsp;
                            <span class="dash-legend-dot dash-dot-female"></span> Female (@Model.FemaleCount)
                        </div>
                    }
                </div>

                <!-- Age group breakdown -->
                <div class="dash-card">
                    <div class="dash-card-title">Age Group Breakdown</div>

                    @if (Model.TotalAccounts == 0)
                    {
                        <p class="text-muted small">No accounts yet.</p>
                    }
                    else
                    {
                        <div class="dash-age-rows">
                            <div class="dash-age-row">
                                <span class="dash-age-label">18–25</span>
                                <div class="dash-age-track">
                                    <div class="dash-age-fill dash-age-c1" style="width:@Model.Ag1p%"></div>
                                </div>
                                <span class="dash-age-count">@Model.AgeGroup1 <span class="text-muted">(@Model.Ag1p%)</span></span>
                            </div>
                            <div class="dash-age-row">
                                <span class="dash-age-label">26–35</span>
                                <div class="dash-age-track">
                                    <div class="dash-age-fill dash-age-c2" style="width:@Model.Ag2p%"></div>
                                </div>
                                <span class="dash-age-count">@Model.AgeGroup2 <span class="text-muted">(@Model.Ag2p%)</span></span>
                            </div>
                            <div class="dash-age-row">
                                <span class="dash-age-label">36–50</span>
                                <div class="dash-age-track">
                                    <div class="dash-age-fill dash-age-c3" style="width:@Model.Ag3p%"></div>
                                </div>
                                <span class="dash-age-count">@Model.AgeGroup3 <span class="text-muted">(@Model.Ag3p%)</span></span>
                            </div>
                            <div class="dash-age-row">
                                <span class="dash-age-label">51+</span>
                                <div class="dash-age-track">
                                    <div class="dash-age-fill dash-age-c4" style="width:@Model.Ag4p%"></div>
                                </div>
                                <span class="dash-age-count">@Model.AgeGroup4 <span class="text-muted">(@Model.Ag4p%)</span></span>
                            </div>
                        </div>
                    }
                </div>

            </div>

            <!-- ── ROW 3: Highlights ── -->
            <div class="dash-card">
                <div class="dash-card-title">Account Highlights</div>
                <div class="dash-highlights">
                    <div class="dash-highlight-item">
                        <span class="dash-highlight-icon"></span>
                        <div>
                            <div class="dash-highlight-label">Most Recently Born</div>
                            <div class="dash-highlight-value">@Model.NewestAccount</div>
                        </div>
                    </div>
                    <div class="dash-highlight-item">
                        <span class="dash-highlight-icon"></span>
                        <div>
                            <div class="dash-highlight-label">Earliest Born</div>
                            <div class="dash-highlight-value">@Model.OldestAccount</div>
                        </div>
                    </div>
                    <div class="dash-highlight-item">
                        <span class="dash-highlight-icon"></span>
                        <div>
                            <div class="dash-highlight-label">Youngest Member</div>
                            <div class="dash-highlight-value">@Model.YoungestAccount</div>
                        </div>
                    </div>
                    <div class="dash-highlight-item">
                        <span class="dash-highlight-icon"></span>
                        <div>
                            <div class="dash-highlight-label">Oldest Member</div>
                            <div class="dash-highlight-value">@Model.OldestByAge</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── ROW 4: Recent registrations ── -->
            <div class="dash-card">
                <div class="dash-card-title">Recently Registered Accounts</div>

                @if (!Model.RecentAccounts.Any())
                {
                    <p class="text-muted small">No accounts registered yet.</p>
                }
                else
                {
                    <table class="table admin-table mb-0">
                        <thead>
                            <tr>
                                <th>USERNAME</th>
                                <th>EMAIL</th>
                                <th>GENDER</th>
                                <th>AGE</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in Model.RecentAccounts)
                            {
                                <tr>
                                    <td class="fw-semibold">@a.Username</td>
                                    <td class="text-muted">@a.Email</td>
                                    <td>
                                        @if (a.Gender == "Male")
                                        {
                                            <span class="status-badge" style="background:#e3f2fd;color:#1565c0;">Male</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge" style="background:#fce4ec;color:#880e4f;">Female</span>
                                        }
                                    </td>
                                    <td>@a.Age yrs</td>
                                    <td>
                                        <a href="/AccountManagement/Index" class="action-btn action-view">View All</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

        </div>
    </main>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>