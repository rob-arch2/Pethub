@page
@model Pethub.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}

<div class="admin-topbar">
    <h4 class="admin-topbar-title">Command Center</h4>
</div>

<div class="admin-table-container">

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="dash-card p-3 text-center">
                <div class="text-muted small fw-bold text-uppercase mb-1">Posts (Last 1hr)</div>
                <div class="fs-3 fw-bold text-dark">@Model.Posts1h</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="dash-card p-3 text-center">
                <div class="text-muted small fw-bold text-uppercase mb-1">Posts (Last 12hr)</div>
                <div class="fs-3 fw-bold text-dark">@Model.Posts12h</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="dash-card p-3 text-center">
                <div class="text-muted small fw-bold text-uppercase mb-1">Posts (Last 24hr)</div>
                <div class="fs-3 fw-bold text-primary">@Model.Posts1d</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="dash-card p-3 text-center">
                <div class="text-muted small fw-bold text-uppercase mb-1">Posts (Last 7 Days)</div>
                <div class="fs-3 fw-bold" style="color: #c97b67;">@Model.Posts7d</div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">

        <div class="col-lg-8">
            <div class="dash-card h-100">
                <div class="dash-card-title border-bottom pb-2 mb-3">Community Activity (7 Days)</div>
                <div style="position: relative; height: 300px; width: 100%;">
                    <canvas id="activityChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="dash-card h-100">
                <div class="dash-card-title border-bottom pb-2 mb-3">Pet Resolution Tracking</div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted fw-bold small text-uppercase">Total Lost Pets</span>
                        <span class="fw-bold text-danger">@Model.TotalLost</span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted fw-bold small text-uppercase">Total Found Pets</span>
                        <span class="fw-bold text-success">@Model.TotalFound</span>
                    </div>

                    @{
                        int totalMissingAndFound = Model.TotalLost + Model.TotalFound;
                        double foundPercentage = totalMissingAndFound > 0 ? ((double)Model.TotalFound / totalMissingAndFound) * 100 : 0;
                    }

                    <div class="mt-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small text-muted">Resolution Rate</span>
                            <span class="small fw-bold">@foundPercentage.ToString("0.0")%</span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: @foundPercentage%" aria-valuenow="@foundPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                </div>

                <hr class="my-4 text-muted" />

                <div class="text-center">
                    <div class="text-muted small fw-bold text-uppercase mb-2">Total Pets Up For Adoption</div>
                    <div class="fs-1 fw-bold" style="color: #3949ab;">@Model.TotalAdoptions</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <div class="col-lg-6">
            <div class="dash-card h-100">
                <div class="dash-card-title border-bottom pb-2 mb-3 d-flex justify-content-between">
                    <span>Recently Joined Users</span>
                    <i class="bi bi-person-plus text-muted"></i>
                </div>

                <div class="d-flex flex-column gap-3">
                    @foreach (var user in Model.RecentAccounts)
                    {
                        <div class="d-flex align-items-center p-2 rounded" style="background: #faf8f4;">
                            <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="width: 40px; height: 40px; background: #c97b67;">
                                @user.Username[0].ToString().ToUpper()
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <div class="fw-bold text-dark" style="font-size: 14px;">@user.Username</div>
                                <div class="text-muted" style="font-size: 12px;">@user.Email</div>
                            </div>
                            <span class="badge bg-light text-dark border">@user.Age yrs</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="dash-card h-100">
                <div class="dash-card-title border-bottom pb-2 mb-3 d-flex justify-content-between">
                    <span>Newly Registered Pets</span>
                    <i class="bi bi-heart text-muted"></i>
                </div>

                <div class="d-flex flex-column gap-3">
                    @foreach (var pet in Model.RecentPets)
                    {
                        <div class="d-flex align-items-center p-2 rounded bg-light border border-light">
                            @if (!string.IsNullOrEmpty(pet.ImagePath))
                            {
                                <img src="@pet.ImagePath" class="rounded" style="width: 40px; height: 40px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="rounded d-flex align-items-center justify-content-center text-muted" style="width: 40px; height: 40px; background: #e2e6ea;">
                                    🐾
                                </div>
                            }
                            <div class="ms-3 flex-grow-1">
                                <div class="fw-bold text-dark" style="font-size: 14px;">@pet.Name <span class="text-muted fw-normal">(@pet.Species)</span></div>
                                <div class="text-muted" style="font-size: 12px;">Owner: @@@pet.Account.Username</div>
                            </div>
                            @if (pet.VaccinationStatus == "Fully Vaccinated")
                            {
                                <i class="bi bi-shield-check text-success"></i>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // Load the data from C#
        const chartLabels = @Html.Raw(Model.ChartLabelsJson);
        const chartData = @Html.Raw(Model.ChartDataJson);

        const ctx = document.getElementById('activityChart').getContext('2d');
        const activityChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: chartLabels,
                datasets: [{
                    label: 'New Posts',
                    data: chartData,
                    borderColor: '#3949ab',
                    backgroundColor: 'rgba(57, 73, 171, 0.1)',
                    borderWidth: 3,
                    pointBackgroundColor: '#c97b67',
                    pointRadius: 4,
                    fill: true,
                    tension: 0.3 // Adds a soft curve to the line
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 } // Only show whole numbers
                    },
                    x: {
                        grid: { display: false }
                    }
                }
            }
        });
    </script>
}