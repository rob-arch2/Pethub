@page
@model Pethub.RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}
<link rel="stylesheet" href="~/css/regis.css">

<div class="navbar">
    <div class="logo">
        <img src="~/images/paws1.png" alt="paw" />
        <span>PETHUB</span>
    </div>
    <div class="menu">
        <a asp-page="/Login">Home</a>
        <a href="#">About</a>
        <a href="#">Services</a>
        <a href="#">Contact</a>
    </div>
    <div class="nav-buttons">
        <a asp-page="/Login" class="login-btn">Login</a>
        <a asp-page="/Register" class="register-btn">Register</a>
    </div>
</div>

<div class="main">
    <div class="registerForm">
        <h2>REGISTER</h2>

        <form method="post">
            <span asp-validation-for="FullName" class="text-danger"></span>
            <input asp-for="FullName" placeholder="Full name" />

            <div class="row">
                <div style="flex:1">
                    <span asp-validation-for="ContactNumber" class="text-danger"></span>
                    <input asp-for="ContactNumber" placeholder="Contact Number (09XXXXXXXXX)" />
                </div>
                <div style="flex:1">
                    <span asp-validation-for="Gender" class="text-danger"></span>
                    <select asp-for="Gender">
                        <option value="">Gender</option>
                        <option>Male</option>
                        <option>Female</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div style="flex:1">
                    <span asp-validation-for="BirthDate" class="text-danger"></span>
                    <input asp-for="BirthDate" type="date" />
                </div>
            </div>

            <span asp-validation-for="Email" class="text-danger"></span>
            <input asp-for="Email" placeholder="Email address" />

            <span asp-validation-for="Password" class="text-danger"></span>
            <div class="password-box">
                <input asp-for="Password" type="password" id="password" placeholder="Create Password (min 8 chars, upper+lower+number)" />
                <button type="button" id="togglePassword" class="toggle-btn">Show</button>
            </div>

            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            <div class="password-box">
                <input asp-for="ConfirmPassword" type="password" id="confirmPassword" placeholder="Re-enter Password" />
                <button type="button" id="toggleConfirmPassword" class="toggle-btn" onclick="togglePassword('confirmPassword','toggleConfirmPassword')">Show</button>
            </div>

            <button type="submit" class="mainBtn">Register</button>
        </form>

        <p class="loginText">
            Already have an account?
            <a asp-page="/Login">Login</a>
        </p>
    </div>

    <div class="catSide">
        <img src="~/images/cat.png" class="catImage" alt="cat">
    </div>
</div>
<script src="~/js/site.js"></script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}