<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pethub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/userdash.css" asp-append-version="true" />
</head>
<body>
    @{
        bool isAdmin = Context.Request.Path.StartsWithSegments("/Admin") || Context.Request.Path.StartsWithSegments("/AccountManagement");
        string currentPath = Context.Request.Path;
    }

    <div class="@(isAdmin ? "admin-wrapper" : "user-wrapper")">

        <aside class="admin-sidebar" id="mainSidebar">
            <div class="admin-sidebar-inner">

                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="admin-logo m-0">
                        <img src="~/images/paws1.png" alt="paw" />
                        <span class="sidebar-text">PETHUB</span>
                    </div>
                    <button id="sidebarToggle" class="btn btn-sm text-white border-0 p-0" style="background:transparent; font-size:1.4rem;">
                        <i class="bi bi-list"></i>
                    </button>
                </div>

                @if (isAdmin)
                {
                    <div class="admin-role-badge sidebar-text">Admin</div>
                    <nav class="admin-nav">
                        <a href="/Admin/Dashboard" class="admin-nav-item @(currentPath.StartsWith("/Admin/Dashboard") ? "active" : "")">
                            <i class="bi bi-speedometer2"></i>
                            <span class="sidebar-text">Dashboard</span>
                        </a>
                        <a href="/AccountManagement/Index" class="admin-nav-item @(currentPath.StartsWith("/AccountManagement") ? "active" : "")">
                            <i class="bi bi-people"></i>
                            <span class="sidebar-text">Manage Users</span>
                        </a>
                        <a href="/Admin/ReportedPosts" class="admin-nav-item @(currentPath.StartsWith("/Admin/ReportedPosts") ? "active" : "")">
                            <i class="bi bi-flag"></i>
                            <span class="sidebar-text">Reported Posts</span>
                        </a>
                        <a href="/Admin/ActivityLogs" class="admin-nav-item @(currentPath.StartsWith("/Admin/ActivityLogs") ? "active" : "")">
                            <i class="bi bi-journal-text"></i>
                            <span class="sidebar-text">Activity Logs</span>
                        </a>
                    </nav>
                }
                else
                {
                    <div class="user-role-badge sidebar-text">User</div>
                    <nav class="admin-nav">
                        <a href="/Landing" class="admin-nav-item @(currentPath == "/Landing" ? "active" : "")">
                            <i class="bi bi-house-door"></i>
                            <span class="sidebar-text">Newsfeed</span>
                        </a>
                        <a href="/Posts/Create" class="admin-nav-item @(currentPath.StartsWith("/Posts/Create") ? "active" : "")">
                            <i class="bi bi-plus-square"></i>
                            <span class="sidebar-text">Create Post</span>
                        </a>
                        <a href="/UserDashboard/Index" class="admin-nav-item @(currentPath == "/UserDashboard/Index" || currentPath == "/UserDashboard" ? "active" : "")">
                            <i class="bi bi-person"></i>
                            <span class="sidebar-text">My Profile</span>
                        </a>
                        <a href="/UserDashboard/ActivityLogs" class="admin-nav-item @(currentPath.StartsWith("/UserDashboard/ActivityLogs") ? "active" : "")">
                            <i class="bi bi-journal-text"></i>
                            <span class="sidebar-text">Activity Logs</span>
                        </a>
                    </nav>
                }

                <div class="admin-sidebar-footer mt-auto">
                    <a href="/Logout" class="admin-logout-btn">
                        <i class="bi bi-box-arrow-right"></i>
                        <span class="sidebar-text">Logout</span>
                    </a>
                </div>
            </div>
        </aside>

        <main class="@(isAdmin ? "admin-main" : "user-main")">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('sidebarToggle').addEventListener('click', function () {
            document.getElementById('mainSidebar').classList.toggle('collapsed');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>