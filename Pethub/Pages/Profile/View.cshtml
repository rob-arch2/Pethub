@page
@model Pethub.Pages.Profile.ViewModel
@{
    ViewData["Title"] = $"{Model.Author.Username}'s Profile";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/newsfeed.css" />

<div class="admin-topbar d-flex justify-content-between align-items-center">
    <h4 class="admin-topbar-title mb-0">@Model.Author.Username's Profile</h4>
    <a href="/Landing" class="action-btn action-view text-decoration-none">← Back to Newsfeed</a>
</div>

<div class="admin-table-container">
    <div class="row g-4">

        {{-- Left: author card --}}
        <div class="col-lg-4">
            <div class="dash-card text-center p-4">

                <div class="mx-auto mb-3 d-flex align-items-center justify-content-center
                            rounded-circle text-white fw-bold"
                     style="width:80px;height:80px;background:#c97b67;
                            font-size:32px;    font-family: system-ui, -apple-system, sans-serif;
                            box-shadow:0 4px 14px rgba(201,123,103,0.35);">
                    @Model.Author.Username[0].ToString().ToUpper()
                </div>

                <h5 class="fw-bold mb-1" style="    font-family: system-ui, -apple-system, sans-serif;color:#2c1a0e;">
                    @Model.Author.Username
                </h5>

                @if (Model.Author.AccountStatus == "Banned")
                {
                    <span class="badge bg-danger mb-3">Banned</span>
                }
                else
                {
                    <span class="badge mb-3" style="background:#e8f5e9;color:#2e7d32;border:1px solid #c8e6c9;">
                        Active Member
                    </span>
                }

                <hr style="border-color:#ddd0b8;" />

                <dl class="row text-start mb-0" style="font-size:14px;line-height:2.2;">
                    <dt class="col-5 text-muted">Gender</dt>
                    <dd class="col-7 fw-semibold">@Model.Author.Gender</dd>

                    <dt class="col-5 text-muted">Location</dt>
                    <dd class="col-7 fw-semibold">@Model.Author.Address</dd>

                    <dt class="col-5 text-muted">Contact</dt>
                    <dd class="col-7 fw-semibold">
                        <a href="tel:@Model.Author.Contact"
                           style="color:#c97b67;text-decoration:none;">
                            @Model.Author.Contact
                        </a>
                    </dd>
                </dl>

            </div>
        </div>

        {{-- Right: their posts --}}
        <div class="col-lg-8">
            <div class="dash-card">
                <div class="dash-card-title border-bottom pb-3 mb-3 d-flex align-items-center gap-2">
                    <span>Posts by @Model.Author.Username</span>
                    <span class="badge bg-secondary rounded-pill">@Model.AuthorPosts.Count</span>
                </div>

                @if (!Model.AuthorPosts.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <div class="fs-1 mb-2">🐾</div>
                        <div class="fw-semibold">No active posts yet.</div>
                    </div>
                }
                else
                {
                    <div class="posts-grid">
                        @foreach (var post in Model.AuthorPosts)
                        {
                            <div class="post-card dash-card p-0">
                                @if (!string.IsNullOrEmpty(post.ImagePath))
                                {
                                    <div class="post-img-wrap">
                                        <img src="@post.ImagePath" alt="Post image" loading="lazy" />
                                    </div>
                                }
                                <div class="post-card-body p-3">
                                    <div class="post-card-header mb-2">
                                        <span class="post-category-badge @CategoryClass(post.Category)">
                                            @post.Category
                                        </span>
                                        @if (post.Price.HasValue && post.Price > 0)
                                        {
                                            <span class="post-price">₱@post.Price.Value.ToString("N0")</span>
                                        }
                                        else
                                        {
                                            <span class="post-free">Free</span>
                                        }
                                    </div>
                                    <h5 class="post-title">@post.Title</h5>
                                    <p class="post-desc text-muted small">@post.Description</p>
                                    <div class="post-meta small">
                                        <span>📍 @post.Location</span>
                                        <span>🕒 @post.CreatedAt.ToString("MMM dd, yyyy")</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@functions {
    static string CategoryClass(string category) => category switch
    {
        "Adoption" => "cat-adoption",
        "Lost Pet" => "cat-lost",
        "For Sale" => "cat-sale",
        "Found Pet" => "cat-found",
        _ => ""
    };
}